{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timekeeper",
  "version": "0.1.0",
  "identifier": "io.timekeeper.app",
  "build": {
    "frontendDist": "http://localhost:4000",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Timekeeper",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/trail"],
    "resources": {
      "binaries/trail-aarch64-apple-darwin": "binaries/trail-aarch64-apple-darwin"
    }
  }
}
